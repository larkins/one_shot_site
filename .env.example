# agieth.ai API Credentials
# Get your API key from https://agieth.ai

# API Configuration
AGIETH_API_KEY=your_api_key_here
AGIETH_EMAIL=your_email@example.com
AGIETH_BASE_URL=https://api.agieth.ai

# User Info (for domain registration - ICANN requires valid contact info)
USER_NAME="Your Name"
USER_ADDRESS="Your Street Address"
USER_CITY="Your City"
USER_POSTAL_CODE="12345"
USER_COUNTRY_CODE="AU"
USER_PHONE="+61 400 000 000"

# Static Server IP (your server's public IP for DNS A records)
STATIC_SERVER_IP=192.168.1.1

# Ethereum Wallet (created by agent from skill.py)
# Generate with: python -c "from skills.agieth.skill import AgiethClient; print(AgiethClient().generate_wallet())"
ETHEREUM_PRIVATE_KEY=0x...your_private_key

# Optional: Override default registrar (namecheap or namesilo)
# REGISTRAR=namecheap